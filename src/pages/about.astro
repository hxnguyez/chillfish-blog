---
import Layout from "../layouts/BlogPost.astro";
import config from "@shConfig";
---

<Layout
  title={config.pages.other.about.title}
  description={config.pages.other.about.subTitle}
  pubDate={new Date("April 22 2026")}
  heroImage={config.pages.other.about.heroImage}
  headings={[]}
>
  <section class="max-w-3xl mx-auto space-y-16 antialiased pb-20">
    
    {/* Section: about.me */}
    <div class="group">
      <h2 class="text-xl font-mono text-amber-500 mb-6 flex items-center gap-2">
        <span class="opacity-50">#</span> about.me
      </h2>
      <div class="space-y-4 text-neutral-400 text-lg leading-relaxed">
        <p class="text-justify [text-justify:inter-word]">
          Hi there! I'm <strong class="text-neutral-100 font-bold">Hung Nguyen</strong> (chillfish)。
          I am currently a student at FPT University, specializing in <span class="text-neutral-200 font-medium border-b border-white/5">Information Assurance</span>。
        </p>
        
        <p class="text-justify [text-justify:inter-word]">
          My technical focus lies deep within the binary level: 
          <span class="text-neutral-200 font-medium border-b border-white/5">Binary Exploitation</span> and 
          <span class="text-neutral-200 font-medium border-b border-white/5">Reverse Engineering</span>。
        </p>

        <p class="text-justify [text-justify:inter-word]">
          The nickname <span class="italic font-mono text-amber-500/80">chillfish</span> reflects my philosophy 
          towards learning — navigating the vast ocean of knowledge with a calm mind, even when 
          confronted by complex machine code and intricate structures。
        </p>
      </div>
    </div>

    {/* Section: Environment */}
    <div class="group">
      <h2 class="text-xl font-mono text-amber-500 mb-6 flex items-center gap-2">
        <span class="opacity-50">#</span> environment
      </h2>
      <div class="text-neutral-400 text-lg leading-relaxed text-justify [text-justify:inter-word]">
        <p>
          My daily workflow is built on <span class="text-neutral-200 font-medium border-b border-white/5">WSL2/Linux</span>, 
          utilizing <span class="text-neutral-200 font-medium border-b border-white/5">GDB (with pwndbg)</span> for vulnerability debugging 
          and <span class="text-neutral-200 font-medium border-b border-white/5">Python</span> for fast exploit development。
        </p>
      </div>
    </div>

    {/* Section: Purpose */}
    <div class="group">
      <h2 class="text-xl font-mono text-amber-500 mb-6 flex items-center gap-2">
        <span class="opacity-50">#</span> site.purpose
      </h2>
      <div class="space-y-4 text-neutral-400 text-lg leading-relaxed text-justify [text-justify:inter-word]">
        <p>
          This blog, powered by <a href="https://astro.build/" class="text-amber-500/80 hover:text-amber-500 transition-colors underline decoration-amber-500/20 underline-offset-4">Astro</a>, 
          functions as a technical diary。
        </p>
        <p>
          My goal when building this blog site is to share my knowledge and experiences in the field of cybersecurity, and to create a personal space where I can document my learning journey, projects, and insights。
          I hope that by sharing my work, I can contribute to the community and connect with like-minded individuals who are passionate about cybersecurity and technology。90% size for the best experience。
        </p>
      </div>
    </div>

    {/* Section: Credits & System Info */}
    <div class="pt-8 border-t border-white/5 group">
      <h2 class="text-sm font-mono text-neutral-500 mb-4 tracking-widest uppercase">
        <span class="opacity-50">#</span> system.info
      </h2>
      <div class="text-neutral-500 text-sm leading-relaxed space-y-2">
        <p>
          Architecture based on <a href="https://astro.build/themes/details/shblog-next/" target="_blank" class="text-neutral-400 hover:text-amber-500 underline decoration-white/10 underline-offset-4 transition-colors">SHBlog Next</a> by SamHacker。
        </p>
        <p>
          Content is licensed under <a href="https://creativecommons.org/licenses/by-nc/4.0/" target="_blank" class="text-neutral-400 hover:text-amber-500 underline decoration-white/10 underline-offset-4 transition-colors">CC BY-NC 4.0</a>。
          Proper attribution is appreciated when sharing。
        </p>
      </div>
    </div>

  </section>
</Layout>