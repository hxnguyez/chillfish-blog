---
import { getCollection } from "astro:content";
import BlogList from "@components/content/BlogList.astro";
import Greeting from "@components/content/Greeting.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@components/content/Home/Hero.astro";
import Sidebar from "@components/Sidebar.astro";
import BaseMainContent from "@/layouts/BaseMainContent.astro";
import { HeroSubtitle, HeroTitle } from "@components/content/Home/HeroItems";
import { SITE_DESCRIPTION, SITE_TITLE } from "@consts";
import config from "@shConfig";
import i18n from "@i18n/translation";
import I18nKey from "@i18n/i18nKey";

const posts = (
  await getCollection("blog", ({ data }) => {
    // 開發環境顯示所有文章,生產環境過濾掉 draft 文章
    if (import.meta.env.DEV) return true;
    return data.draft !== true;
  })
)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6); // Get latest 6 posts

const featuredPost = posts[0];
const currentPage = Number(Astro.url.searchParams.get("page")) || 1;
---

<BaseLayout
  title={SITE_TITLE}
  description={SITE_DESCRIPTION}
  coverImage={config.pages.home.heroImage}
>
  <!-- Hero Section -->
  <Hero>
    <!-- Left: Main heading -->
    <div class="lg:col-span-2" slot="left">
      <HeroTitle>
        <span class="whitespace-pre-line">{config.pages.home.title}</span>
      </HeroTitle>
      <HeroSubtitle slot="right">
        <Greeting />
      </HeroSubtitle>
    </div>
    <!-- Right: Featured article card -->
    {
      config.style.enableRecentPosts && (
        <div class="flex flex-col items-end justify-end gap-5" slot="right">
          {featuredPost && (
            <a
              href={`/blog/${featuredPost.id}/`}
              class="group flex h-57.5 w-[380px] flex-col justify-end overflow-hidden rounded-xl border border-white/20 bg-black/30 p-6 backdrop-blur-sm transition-all hover:bg-black/50"
              style={{
                backgroundImage: featuredPost.data.heroImage
                  ? `url(${featuredPost.data.heroImage.src})`
                  : config.style.defaultPostImage,
                backgroundSize: "cover",
                backgroundBlendMode: "darken",
              }}
            >
              <p class="mb-2.5 text-xl tracking-[4px] text-white/60">
                {i18n(I18nKey.home_recent_posts)}
              </p>
              <h2 class="text-4xl font-bold text-white transition-colors group-hover:text-white/90">
                {featuredPost.data.title}
              </h2>
            </a>
          )}
        </div>
      )
    }
  </Hero>

  <!-- Main content section -->
  <BaseMainContent>
    <!-- Main column: Blog posts grid -->
    <div class="flex-1" data-pagefind-body transition:name="main-content">
      <BlogList currentPage={currentPage} />
    </div>

    <!-- Sidebar -->
    <aside class="hidden shrink-0 lg:block lg:w-[300px] xl:w-[380px]">
      <Sidebar />
    </aside>
  </BaseMainContent>
</BaseLayout>
