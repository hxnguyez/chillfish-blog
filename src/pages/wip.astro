---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@components/content/Home/Hero.astro";
import { HeroTitle, HeroSubtitle } from "@components/content/Home/HeroItems";
import BaseMainContent from "@/layouts/BaseMainContent.astro";
import Sidebar from "@components/Sidebar.astro";
import TimelineSinglePost from "@ui/timeline/TimelineSinglePost.astro";
import config from "@shConfig";

const allLogs = await getCollection("wip", ({ data }) => {
  if (import.meta.env.DEV) return true;
  return data.draft !== true;
});

const now = new Date();
const currentYear = now.getFullYear();
const currentMonth = now.getMonth();
const years = [2027, 2026];

// Helper function để lấy YYYY-MM-DD theo múi giờ địa phương (Local Time)
function getLocalDateString(date: Date) {
  const d = new Date(date);
  return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
}

function getYearGridData(year: number) {
  const startDate = new Date(year, 0, 1);
  const startDayOfWeek = startDate.getDay();
  const diff = startDate.getDate() - startDayOfWeek + (startDayOfWeek === 0 ? -6 : 1);
  const calendarStart = new Date(startDate.setDate(diff));
  
  const days = Array.from({ length: 371 }, (_, i) => {
    const d = new Date(calendarStart);
    d.setDate(d.getDate() + i);
    return d;
  });

  const yearLogs = allLogs.filter(log => new Date(log.data.pubDate).getFullYear() === year);
  const logCounts = yearLogs.reduce((acc: any, log) => {
    const dateKey = getLocalDateString(new Date(log.data.pubDate));
    acc[dateKey] = (acc[dateKey] || 0) + 1;
    return acc;
  }, {});

  return { days, logCounts, yearLogs };
}

const pageConfig = config.pages.other?.wip || {
  title: "Work In Progress",
  subTitle: "Daily logs & Development history",
  heroImage: config.pages.blog.heroImage 
};
const { title, subTitle, heroImage } = pageConfig;
---

<BaseLayout title={title} description={subTitle} coverImage={heroImage}>
  <Hero backgroundImage={heroImage}>
    <div class="lg:col-span-2" slot="left">
      <HeroTitle><span class="whitespace-pre-line text-white">{title}</span></HeroTitle>
      <HeroSubtitle>{subTitle}</HeroSubtitle>
    </div>
  </Hero>

  <BaseMainContent>
    <div class="flex-1">
      <div class="mb-10 rounded-xl border border-[#30363d] bg-[#0d1117] p-6 shadow-sm">
        <div class="mb-6 flex items-center justify-between">
          <h3 class="text-sm font-bold text-white uppercase tracking-wider">Activity History</h3>
          <div class="flex bg-[#161b22] p-1 rounded-lg border border-[#30363d]">
            {years.map((y) => (
              <button 
                data-year-target={y}
                class={`year-btn px-4 py-1 text-xs font-bold rounded-md transition-all ${y === currentYear ? 'bg-[#21262d] text-white border border-[#30363d]' : 'text-[#8b949e] hover:text-white cursor-pointer'}`}
              >
                {y}
              </button>
            ))}
          </div>
        </div>
        
        {years.map((y) => {
          const { days, logCounts } = getYearGridData(y);
          return (
            <div id={`grid-${y}`} class={`year-grid-content w-full overflow-hidden ${y === currentYear ? 'block' : 'hidden'}`}>
              <div class="grid grid-rows-7 grid-flow-col gap-[2px] w-max relative isolation-isolate" id="contribution-grid">
                {days.map((date) => {
                  const dateStr = getLocalDateString(date);
                  const count = logCounts[dateStr] || 0;
                  const isCurrentYear = date.getFullYear() === y;
                  const tooltipDate = date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

                  return (
                    <div
                      data-date={dateStr}
                      data-month={date.getMonth()}
                      class={`h-3 w-3 rounded-[1.5px] transition-all relative group/item
                        ${!isCurrentYear ? 'opacity-0 pointer-events-none' : ''}
                        ${count > 0 ? 'bg-[#39d353] shadow-[0_0_8px_rgba(57,211,83,0.4)] cursor-pointer hover:scale-110' : 'bg-[#161b22] pointer-events-none'}
                      `}
                    >
                      <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 px-2 py-1 bg-[#6e7681] text-white text-[10px] rounded pointer-events-none opacity-0 group-hover/item:opacity-100 transition-opacity whitespace-nowrap z-[100] shadow-xl">
                        {count} contributions on {tooltipDate}
                        <div class="absolute top-full left-1/2 -translate-x-1/2 border-4 border-transparent border-t-[#6e7681]"></div>
                      </div>
                    </div>
                  );
                })}
              </div>
              <div class="mt-4 flex justify-between text-[9px] text-[#484f58] font-mono w-full px-1 uppercase opacity-60">
                {['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'].map((m, index) => (
                  <span class="month-label cursor-pointer hover:text-green-500 transition-colors" data-year={y} data-month={index}>{m}</span>
                ))}
              </div>
            </div>
          );
        })}
      </div>

      <div class="mb-8 flex items-center justify-between border-b border-[#30363d] pb-4">
        <h2 id="log-title" class="text-xl font-bold text-gray-900 dark:text-white uppercase tracking-tight">Logs</h2>
        <button id="reset-filter" class="text-xs text-green-500 hover:underline cursor-pointer">Show all year</button>
      </div>

      <div id="logs-list" class="space-y-2">
        {allLogs.sort((a,b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).map((post) => {
          const dateObj = new Date(post.data.pubDate);
          const dateStr = getLocalDateString(dateObj);
          const displayDate = dateObj.toLocaleDateString('en-US', { month: '2-digit', day: '2-digit' }).replace('/', '-');
          
          return (
            <div class="log-item group relative flex items-center gap-4 pl-4 transition-all hover:bg-[#161b22]/50 rounded-xl border border-transparent hover:border-[#30363d] p-2" 
              data-date={dateStr} 
              data-month={dateObj.getMonth()}
              data-year={dateObj.getFullYear()}
            >
               {/* text-neutral-300 */}
               <span class="text-[10px] font-mono text-neutral-300 min-w-[40px] select-none">[{displayDate}]</span>
               <div class={`h-2.5 w-2.5 rounded-full shrink-0 ${getLocalDateString(dateObj) === getLocalDateString(now) ? 'bg-green-500 ring-4 ring-green-500/20 shadow-[0_0_8px_rgba(34,197,94,0.6)]' : 'bg-[#30363d]'}`}></div>
               <div class="flex-1 overflow-hidden">
                 <TimelineSinglePost postData={post} postTags={post.data.tags || []} />
               </div>
            </div>
          );
        })}
      </div>
    </div>
    <aside class="hidden shrink-0 lg:block lg:w-[300px] xl:w-[380px]"><Sidebar /></aside>
  </BaseMainContent>
</BaseLayout>

<script is:inline define:vars={{ currentMonth, currentYear }}>
  function initWipTabs() {
    const yearBtns = document.querySelectorAll('.year-btn');
    const grids = document.querySelectorAll('.year-grid-content');
    const logItems = document.querySelectorAll('.log-item');
    const logTitle = document.getElementById('log-title');
    const resetBtn = document.getElementById('reset-filter');
    
    let activeYear = currentYear;

    function updateView(year, month = null) {
      yearBtns.forEach(btn => {
        if (parseInt(btn.dataset.yearTarget) === year) {
          btn.classList.add('bg-[#21262d]', 'text-white', 'border', 'border-[#30363d]');
          btn.classList.remove('text-[#8b949e]');
        } else {
          btn.classList.remove('bg-[#21262d]', 'text-white', 'border', 'border-[#30363d]');
          btn.classList.add('text-[#8b949e]');
        }
      });

      grids.forEach(g => g.classList.toggle('hidden', g.id !== `grid-${year}`));

      logItems.forEach(log => {
        const yMatch = parseInt(log.dataset.year) === year;
        const mMatch = month === null || parseInt(log.dataset.month) === month;
        log.style.display = (yMatch && mMatch) ? 'flex' : 'none';
      });

      if (logTitle) {
        if (month !== null) {
          const names = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
          logTitle.innerText = `${names[month]} ${year}`;
        } else {
          logTitle.innerText = `Logs of ${year}`;
        }
      }
    }

    yearBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        activeYear = parseInt(btn.dataset.yearTarget);
        updateView(activeYear, activeYear === currentYear ? currentMonth : null);
      });
    });

    document.querySelectorAll('.month-label').forEach(label => {
      label.addEventListener('click', () => {
        updateView(parseInt(label.dataset.year), parseInt(label.dataset.month));
      });
    });

    document.querySelectorAll('[data-date]').forEach(sq => {
      sq.addEventListener('click', () => {
        const d = sq.dataset.date;
        logItems.forEach(log => log.style.display = log.dataset.date === d ? 'flex' : 'none');
        if (logTitle) logTitle.innerText = `Logs for ${d}`;
      });
    });

    resetBtn?.addEventListener('click', () => updateView(activeYear));

    updateView(currentYear, currentMonth);
  }

  document.addEventListener('astro:page-load', initWipTabs);
  initWipTabs();
</script>

<style>
  .overflow-hidden { scrollbar-width: none; -ms-overflow-style: none; }
  .overflow-hidden::-webkit-scrollbar { display: none; }
  #contribution-grid { isolation: isolate; }
  .group\/item:hover { z-index: 50; }
  
  .log-item {
    display: flex;
    align-items: center;
    min-height: 44px;
  }

  .log-item :global(a) {
    display: flex !important;
    align-items: center !important;
    gap: 0.75rem !important;
    padding: 0 !important;
    background: transparent !important;
    width: 100%;
  }

  .log-item :global(h3) {
    font-size: 0.875rem !important;
    margin-bottom: 0 !important;
    white-space: nowrap;
    font-weight: 600 !important;
  }

  .log-item :global(.inline-flex) {
    font-size: 10px !important;
    padding-top: 0.125rem !important;
    padding-bottom: 0.125rem !important;
    height: 1.25rem !important;
    margin-top: 0 !important;
    border-color: #30363d !important;
    background-color: #161b22 !important;
  }
  
  .log-item :global(svg) {
    width: 10px !important;
    height: 10px !important;
  }
</style>