---
import { getCollection } from "astro:content";
import BlogList from "@components/content/BlogList.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@components/content/Home/Hero.astro";
import Sidebar from "@components/Sidebar.astro";
import BaseMainContent from "@/layouts/BaseMainContent.astro";
import { HeroSubtitle, HeroTitle } from "@components/content/Home/HeroItems";
import config from "@shConfig";

const labPosts = await getCollection("lab", ({ data }) => {
  if (import.meta.env.DEV) return true;
  return data.draft !== true;
});

const researchPosts = await getCollection("research", ({ data }) => {
  if (import.meta.env.DEV) return true;
  return data.draft !== true;
});
console.log("👉 [DEBUG] Số bài viết trong Research:", researchPosts.length);
console.log("👉 [DEBUG] Số bài viết trong Lab:", labPosts.length);

labPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
researchPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featuredLab = researchPosts[0] || labPosts[0];
const currentPage = Number(Astro.url.searchParams.get("page")) || 1;
const { title, subTitle, heroImage } = config.pages.other.lab;
---

<BaseLayout title={title} description={subTitle} coverImage={heroImage}>
  <Hero backgroundImage={heroImage}>
    <div class="lg:col-span-2" slot="left">
      <HeroTitle>
        <span class="whitespace-pre-line">{title}</span>
      </HeroTitle>
      <HeroSubtitle>
        {subTitle}
      </HeroSubtitle>
    </div>

    {featuredLab && (
      <div class="flex flex-col items-end justify-end gap-5" slot="right">
        <a
          href={`/${featuredLab.collection}/${featuredLab.id}/`}
          class="group flex h-57.5 w-[380px] flex-col justify-end overflow-hidden rounded-xl border border-white/20 bg-black/30 p-6 backdrop-blur-sm transition-all hover:bg-black/50"
          style={{
            backgroundImage: featuredLab.data.heroImage
              ? `url(${featuredLab.data.heroImage})`
              : `url(${config.style.heroImage.src})`,
            backgroundSize: "cover",
            backgroundPosition: "center",
            backgroundBlendMode: "darken",
          }}
        >
          <p class="mb-2.5 text-xl tracking-[4px] text-white/60 uppercase">
            {featuredLab.collection === 'research' ? 'LATEST RESEARCH' : 'LATEST TOOL'}
          </p>
          <h2 class="text-2xl font-bold text-white transition-colors group-hover:text-white/90 line-clamp-2">
            {featuredLab.data.title}
          </h2>
        </a>
      </div>
    )}
  </Hero>

  <BaseMainContent>
    <div class="flex-1" data-pagefind-body transition:name="main-content">
      
      <div class="mb-8 flex items-center justify-between border-b border-[#30363d] pb-4">
        <div class="inline-flex p-1 bg-[#161b22] border border-[#30363d] rounded-lg">
          <button 
            id="btn-research" 
            class="px-4 py-1.5 text-sm font-semibold rounded-md transition-all cursor-pointer bg-[#21262d] text-white shadow-sm border border-[#30363d]"
          >
            Research
          </button>
          <button 
            id="btn-lab" 
            class="px-4 py-1.5 text-sm font-semibold rounded-md transition-all cursor-pointer text-[#8b949e] border border-transparent hover:text-white"
          >
            Lab
          </button>
        </div>
      </div>

      <div id="content-research" class="animate-fade-in" style="display: block;">
        {researchPosts.length > 0 ? (
          <BlogList posts={researchPosts} collection="research" />
        ) : (
          <div class="rounded-xl border border-[#30363d] bg-[#0d1117] p-12 text-center text-[#8b949e]">
            <p class="text-sm font-medium">Where is the post?</p>
            <p class="text-xs mt-1">In progress...</p>
          </div>
        )}
      </div>

      <div id="content-lab" class="animate-fade-in" style="display: none;">
        {labPosts.length > 0 ? (
          <BlogList posts={labPosts} collection="lab" />
        ) : (
          <div class="rounded-xl border border-[#30363d] bg-[#0d1117] p-12 text-center text-[#8b949e]">
            <p class="text-sm font-medium">Where is the post?</p>
            <p class="text-xs mt-1">Setting up the lab...</p>
          </div>
        )}
      </div>

    </div>

    <aside class="hidden shrink-0 lg:block lg:w-[300px] xl:w-[380px]">
      <Sidebar />
    </aside>
  </BaseMainContent>
</BaseLayout>

<script>
  function setupTabs() {
    const btnResearch = document.getElementById('btn-research');
    const btnLab = document.getElementById('btn-lab');
    const contentResearch = document.getElementById('content-research');
    const contentLab = document.getElementById('content-lab');

    if (!btnResearch || !btnLab || !contentResearch || !contentLab) return;

    const activeClasses = ['bg-[#21262d]', 'text-white', 'shadow-sm', 'border-[#30363d]'];
    const inactiveClasses = ['text-[#8b949e]', 'border-transparent', 'hover:text-white'];

    function showResearch() {
      contentResearch.style.display = 'block';
      contentLab.style.display = 'none';
      
      btnResearch.classList.add(...activeClasses);
      btnResearch.classList.remove(...inactiveClasses);
      
      btnLab.classList.remove(...activeClasses);
      btnLab.classList.add(...inactiveClasses);
    }

    function showLab() {
      contentLab.style.display = 'block';
      contentResearch.style.display = 'none';
      
      btnLab.classList.add(...activeClasses);
      btnLab.classList.remove(...inactiveClasses);
      
      btnResearch.classList.remove(...activeClasses);
      btnResearch.classList.add(...inactiveClasses);
    }

    btnResearch.addEventListener('click', showResearch);
    btnLab.addEventListener('click', showLab);

    // Set initial state
    showResearch();
  }

  document.addEventListener('astro:page-load', setupTabs);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupTabs);
  } else {
    setupTabs();
  }
</script>