---
import { type CollectionEntry, getCollection, render } from "astro:content";
import BlogPost from "../../layouts/BlogPost.astro";

// 1. Sinh ra các đường dẫn tĩnh cho từng bài viết trong collection 'lab'
export async function getStaticPaths() {
  const posts = await getCollection("lab", ({ data }) => {
    // Hiển thị tất cả ở môi trường dev, ẩn bản nháp ở môi trường production
    if (import.meta.env.DEV) return true;
    return data.draft !== true;
  });

  return posts.map((post) => ({
    params: { slug: post.id }, // Dùng id làm slug cho URL
    props: post,
  }));
}

// 2. Định nghĩa kiểu dữ liệu cho Props
type Props = CollectionEntry<"lab">;

const post = Astro.props;
const { Content, headings } = await render(post);

// 3. Import các component xử lý định dạng đặc biệt trong Markdown
const ImagePacked = (await import("@components/markdown/ImagePacked.astro")).default;
const BlockQuotePacked = (await import("@components/markdown/BlockQuotePacked.astro")).default;
---

<BlogPost {...post.data} collection="lab" headings={headings}>
  {/* Đổ nội dung Markdown vào Layout, kèm theo các component xử lý ảnh và blockquote */}
  <Content
    components={{
      img: ImagePacked,
      blockquote: BlockQuotePacked,
    }}
  />
</BlogPost>