---
import "@/styles/markdown.css";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import FormattedDate from "@components/content/FormattedDate.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import BaseMainContent from "@/layouts/BaseMainContent.astro";
import Hero from "@components/content/Home/Hero.astro";
import { HeroTitle, HeroSubtitle } from "@components/content/Home/HeroItems";
import Sidebar from "@components/Sidebar.astro";
import { CalendarDays, Tag, User } from "lucide-react";
import config from "@shConfig";
import { Separator } from "@components/ui/separator";
import { DEFAULT_POST_IMAGE, SEPARATOR } from "@consts";
import "@/styles/aside.css";
import Toc from "@components/Toc.astro";
import "katex/dist/katex.min.css";
import Tags from "@components/Tags.astro";
import i18n from "@i18n/translation";
import I18nKey from "@i18n/i18nKey";
import CVEInfo from "@components/post/CVEInfo.astro";

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: any;
  collection?: "blog" | "lab" | "research" | "wip";
  headings: Array<{ depth: number; slug: string; text: string }>;
  tags?: CollectionEntry<"blog">["data"]["tags"];
}

const { title, description, pubDate, updatedDate, heroImage, collection = "blog", headings, tags } = Astro.props;

// Dữ liệu bổ sung cho Pagefind
const data = (Astro.props as any).data || (Astro.props as any).frontmatter || Astro.props;
const { cveId, severity, cvss, category } = data;
---

<BaseLayout title={`${title} ${SEPARATOR} ${config.title}`} description={description ?? ""} coverImage={heroImage}>
  <Hero backgroundImage={heroImage || DEFAULT_POST_IMAGE}>
    <div class="lg:col-span-2" slot="left">
      <HeroTitle>{title}</HeroTitle>
      <HeroSubtitle slot="right">{description ?? ""}</HeroSubtitle>
    </div>
  </Hero>

  <BaseMainContent>
    <article data-pagefind-body class="w-full max-w-full min-w-0 flex-1">
      
      {/* 1. TRẠM BƠM DỮ LIỆU: Filter cho Pagefind */}
      <div class="hidden">
        {category && <span data-pagefind-filter="category">{category}</span>}
        {tags && tags.map((t: string) => (
          <span data-pagefind-filter="tags">{t}</span>
        ))}
      </div>

      <div class="mb-4 flex flex-wrap gap-y-2 gap-x-4" data-pagefind-ignore>
        <time class="flex items-center gap-1 text-sm text-gray-500">
          <CalendarDays size={18} />
          {i18n(I18nKey.post_released)} <FormattedDate date={pubDate} />
        </time>
        <div class="flex items-center gap-1 text-sm text-gray-500">
          <User size={18} />
          {i18n(I18nKey.post_author)} <span class="font-medium text-gray-300">{config.author.name}</span>
        </div>
      </div>

      {/* 2. NỘI DUNG CHÍNH */}
      <div class="mt-10 markdown-body prose prose-invert max-w-none" id="post-content" data-pagefind-ignore="all">
        <slot />
      </div>

      {/* ĐÃ XÓA PHẦN COMMENT TẠI ĐÂY */}
      <div class="mt-16 border-t border-white/10 pt-10" data-pagefind-ignore>
         {/* Khoảng trống cuối bài */}
      </div>
    </article>

    <aside class="hidden shrink-0 lg:block lg:w-[300px] xl:w-[380px]">
      <div class="sticky top-24 flex flex-col gap-4 h-[calc(100vh-8rem)]">
        
        {/* BẢNG CVE */}
        {cveId && (
          <div class="shrink-0" data-pagefind-ignore>
            <CVEInfo id={cveId} severity={severity} cvss={cvss} />
          </div>
        )}
        
        {/* TOC */}
        {headings?.length > 0 && config.behavior.tableOfContents.enable && (
          <div class="flex-1 min-h-0 w-full toc-wrapper" data-pagefind-ignore>
            <Toc {headings} />
          </div>
        )}

      </div>
    </aside>
  </BaseMainContent>
</BaseLayout>

<style is:global>
  /* GHI ĐÈ CSS CỦA TOC: Ép nó lấp đầy khung */
  .toc-wrapper #toc {
    margin-top: 0 !important;
    height: 100% !important;
    max-height: 100% !important;
    display: flex;
    flex-direction: column;
  }
  .toc-wrapper #toc > div {
    height: 100% !important;
    max-height: 100% !important;
    display: flex;
    flex-direction: column;
  }
  .toc-wrapper nav {
    flex: 1;
    overflow-y: auto !important;
  }
  
  /* FIX THANH CUỘN TOC: Chuyển sang tông Amber đồng bộ */
  .toc-wrapper nav::-webkit-scrollbar { width: 4px !important; }
  .toc-wrapper nav::-webkit-scrollbar-track { background: transparent !important; }
  .toc-wrapper nav::-webkit-scrollbar-thumb { 
    background: rgba(245, 158, 11, 0.3) !important; 
    border-radius: 10px !important; 
  }
  .toc-wrapper nav::-webkit-scrollbar-thumb:hover { 
    background: #f59e0b !important; 
  }
</style>

<script>
  const initCopyButtons = () => {
    document.addEventListener("click", (e) => {
      const target = e.target as Element | null;
      if (target?.classList.contains("copy-btn")) {
        const codeEle = target.closest("pre")?.querySelector("code");
        if (!codeEle) return;
        const code = Array.from(codeEle.querySelectorAll(".code:not(summary *)")).map(el => el.textContent).join("\n");
        navigator.clipboard.writeText(code).then(() => {
          target.classList.add("success");
          setTimeout(() => target.classList.remove("success"), 2000);
        });
      }
    });
  };
  document.addEventListener("astro:page-load", initCopyButtons);
</script>