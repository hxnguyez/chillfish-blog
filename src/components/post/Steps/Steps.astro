---
import { cn } from "@lib/utils";

interface Props {
  start?: number; 
  class?: string;
}

const { start = 1, class: className } = Astro.props;
const counterStartValue = start - 1;
---

<div
  class={cn(
    "sh-builtin-components steps-container flex flex-col mb-6",
    className,
  )}
  style={`--start-index: ${counterStartValue};`}
>
  <slot />
</div>

<style>
  .steps-container {
    counter-reset: step-counter var(--start-index);
  }
</style>