---
interface Props {
  id?: string;
  severity?: string;
  cvss?: string;
}
const { id, severity, cvss } = Astro.props;

const severityStyles = {
  "CRITICAL": "text-red-500 border-red-500/30 bg-red-500/10 shadow-[0_0_10px_rgba(239,68,68,0.2)]",
  "HIGH": "text-orange-500 border-orange-500/30 bg-orange-500/10",
  "MEDIUM": "text-yellow-500 border-yellow-500/30 bg-yellow-500/10",
}[severity || ""] || "text-amber-400 border-amber-400/30 bg-amber-400/10";
---

<div class="w-full border border-white/10 rounded-xl bg-neutral-900/60 backdrop-blur-md overflow-hidden mb-2">
  <div class="border-b border-white/10 px-4 py-2.5 bg-white/5 flex justify-between items-center">
     <span class="text-[10px] font-bold tracking-[0.2em] text-amber-500 uppercase">CVE Details</span>
     <span class="h-2 w-2 rounded-full bg-amber-500 animate-pulse shadow-[0_0_8px_#f59e0b]"></span>
  </div>
  <div class="p-4 space-y-4">
    <div>
      <div class="text-[9px] text-neutral-500 uppercase mb-1">Standard Identifier</div>
      <div class="text-base font-mono font-bold text-white">{id}</div>
    </div>
    <div class="grid grid-cols-2 gap-4">
      <div>
        <div class="text-[9px] text-neutral-500 uppercase mb-1">Severity</div>
        <div class={`text-[10px] font-bold px-2 py-0.5 border rounded-md text-center ${severityStyles}`}>
          {severity}
        </div>
      </div>
      <div>
        <div class="text-[9px] text-neutral-500 uppercase mb-1">CVSS Score</div>
        <div class="text-base font-mono font-bold text-white">{cvss}</div>
      </div>
    </div>
  </div>
</div>