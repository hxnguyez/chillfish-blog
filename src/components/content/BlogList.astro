---
import { getCollection } from "astro:content";
import BlogListClient from "./BlogListClient.tsx";
import config from "@shConfig";

interface Props {
  posts?: any[];
  collection?: "blog" | "lab" | "research";
}

const { posts: propsPosts, collection = "blog" } = Astro.props;
const postsPerPage = config.style.postsPerPage || 6;
const typedCollection = collection as "blog" | "lab" | "research";

const allPosts = propsPosts || (
  await getCollection(typedCollection, ({ data }: any) => {
    return data.draft !== true && !!data.title;
  })
).sort((a: any, b: any) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const serializedPosts = allPosts.map((post: any) => {
  let finalImage = config.style.defaultPostImage || "/assets/blog/orange.jpg";
  
  if (post.data.heroImage) {
    if (typeof post.data.heroImage === 'string') {
      finalImage = post.data.heroImage;
    } else if (post.data.heroImage.src) {
      finalImage = post.data.heroImage.src;
    }
  }

  const d = post.data.pubDate instanceof Date ? post.data.pubDate : new Date(post.data.pubDate);
  const formattedDate = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;

  return {
    id: post.id,
    data: {
      title: post.data.title,
      description: post.data.description,
      pubDate: formattedDate, 
      heroImage: finalImage,
      category: post.data.category ?? null,
      tags: post.data.tags ?? null,
    },
  };
});
---

<BlogListClient
  client:load
  posts={serializedPosts}
  collection={collection}
  postsPerPage={postsPerPage}
/>