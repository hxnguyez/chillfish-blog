---
import { Hash } from "lucide-react";
import { Badge } from "@ui/badge";

interface Props {
  postData: any;
  postTags: string[];
}

const { postData, postTags } = Astro.props;
---

<a
  href={`/blog/${postData.id}/`}
  class="align-center flex flex-wrap rounded-lg p-4 transition-all"
>
  <h3
    class="mb-2 text-center text-xl font-semibold text-gray-900 transition-colors group-hover:text-green-500 dark:text-white"
  >
    {postData.data.title}
  </h3>
  <div class="mt-2 ml-4 flex flex-wrap justify-center gap-2">
    {
      postTags.map((t: string) => (
        <Badge
          variant="secondary"
          className="px-2 text-sm hover:bg-secondary/90 transition-all"
          client:only
        >
          <Hash size={14} />
          {t}
        </Badge>
      ))
    }
  </div>
</a>
