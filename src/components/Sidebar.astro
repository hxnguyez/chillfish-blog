---
import config from "@shConfig";
import AuthorCard from "./widgets/AuthorCard";
import DiscordCard from "./widgets/DiscordCard";

// Nhận biến isPost để biết đang ở đâu
interface Props {
  isPost?: boolean;
}
const { isPost = false } = Astro.props;
---

<div class="sticky top-24 flex w-full flex-col gap-5 max-h-[calc(100vh-6rem)]" data-pagefind-ignore>
  
  {/* Chỉ hiện Author và Discord nếu KHÔNG PHẢI là bài viết Blog */}
  {!isPost && (
    <div class="flex flex-col gap-5 shrink-0">
      <AuthorCard
        client:load
        image={config.author.avatarUrl}
        name={config.author.name}
        slug={config.author.name.toLowerCase().replace(/\s+/g, "")}
        description={config.author.bio}
        links={config.author.links}
        transition:name="sidebar"
      />

      <a href="https://discord.com/users/876338724890349569" target="_blank" rel="noopener noreferrer">
        <DiscordCard
          client:load
          title="Discord"
          subtitle="Connect with hxnguyez"
          description="Drop me a DM if you have any questions about this blog, or just want to chat!"
        />
      </a>
    </div>
  )}

  {/* ToC và CVE sẽ luôn nằm trong slot này */}
  <div class="flex-1 overflow-y-auto pr-2 custom-scrollbar-mini select-none">
    <slot />
  </div>
</div>

<style>
  /* Giữ nguyên CSS scrollbar cũ của Hưng */
  .custom-scrollbar-mini::-webkit-scrollbar { width: 4px; }
  .custom-scrollbar-mini::-webkit-scrollbar-thumb { background: #30363d; border-radius: 10px; }
</style>