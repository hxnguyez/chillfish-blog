---
const FORMSPREE_URL = "https://formspree.io/f/mjglapjw"; 
---

<div class="w-full max-w-2xl mx-auto border border-white/10 rounded-2xl bg-neutral-900/40 backdrop-blur-md p-8 shadow-2xl relative overflow-hidden mt-10" data-pagefind-ignore>
  <div class="absolute -top-24 -right-24 h-48 w-48 bg-amber-500/10 blur-[80px] rounded-full"></div>

  <div class="relative z-10">
    <h2 class="text-2xl font-bold text-white mb-2 flex items-center gap-3">
      <span class="h-2 w-2 bg-amber-500 rounded-full shadow-[0_0_10px_#f59e0b] animate-pulse"></span>
      CONTACT FORM
    </h2>
    <p class="text-[10px] text-neutral-500 uppercase tracking-[0.2em] mb-8 font-mono opacity-70">
      Connect with me through the form below. Whether you have questions, collaboration ideas, or just want to say hi, I'll get back to you as soon as possible!
    </p>

    <form action={FORMSPREE_URL} method="POST" class="space-y-6">
      
      <input type="text" name="_gotcha" style="display:none" />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="space-y-2">
          <label class="block text-[10px] uppercase tracking-widest text-amber-500 font-bold ml-1">Identity</label>
          <input 
            type="text" 
            name="name" 
            required
            placeholder="Your Name / Alias"
            class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-amber-500/50 focus:ring-1 focus:ring-amber-500/50 transition-all placeholder:text-neutral-700"
          />
        </div>

        <div class="space-y-2">
          <label class="block text-[10px] uppercase tracking-widest text-amber-500 font-bold ml-1">Email</label>
          <input 
            type="email" 
            name="email" 
            required
            placeholder="your@email.com"
            class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-amber-500/50 focus:ring-1 focus:ring-amber-500/50 transition-all placeholder:text-neutral-700"
          />
        </div>
      </div>

      <div class="space-y-2">
        <label class="block text-[10px] uppercase tracking-widest text-amber-500 font-bold ml-1">Contact Content</label>
        <textarea 
          name="message" 
          rows="5" 
          required
          placeholder="Enter your message here..."
          class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-amber-500/50 focus:ring-1 focus:ring-amber-500/50 transition-all resize-none placeholder:text-neutral-700 custom-scrollbar-mini"
        ></textarea>
      </div>

      <div class="pt-2">
        <button 
          type="submit" 
          class="group relative w-full bg-neutral-950 border border-amber-500/30 hover:border-amber-500 overflow-hidden py-4 rounded-xl transition-all active:scale-[0.98]"
        >
          <div class="absolute inset-0 bg-amber-500/10 translate-y-full group-hover:translate-y-0 transition-transform duration-300"></div>
          
          <span class="relative z-10 text-amber-500 font-bold uppercase tracking-[0.3em] text-[11px] group-hover:text-white transition-colors">
            Submit
          </span>
        </button>
      </div>
      
      <div class="flex items-center justify-center gap-4 pt-2">
         <p class="text-[9px] text-neutral-600 font-mono italic">
           Protocol: HTTPS/TLS 1.3
         </p>
         <span class="h-1 w-1 bg-neutral-700 rounded-full"></span>
         <p class="text-[9px] text-neutral-600 font-mono italic">
           Filter: Anti-Bot Active
         </p>
      </div>
    </form>
  </div>
</div>

<style>
  /* Thanh cuộn nhỏ gọn cho textarea */
  .custom-scrollbar-mini::-webkit-scrollbar { width: 4px; }
  .custom-scrollbar-mini::-webkit-scrollbar-track { background: transparent; }
  .custom-scrollbar-mini::-webkit-scrollbar-thumb { 
    background: rgba(245, 158, 11, 0.2); 
    border-radius: 10px; 
  }
  .custom-scrollbar-mini::-webkit-scrollbar-thumb:hover { 
    background: rgba(245, 158, 11, 0.5); 
  }
</style>