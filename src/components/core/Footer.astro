---
import config from "@shConfig";

let year: number | null = null;
if (config.footer.copyright.yearUpdateStrategy === "fixed") {
  year = new Date().getFullYear();
} else if (typeof config.footer.copyright.yearUpdateStrategy === "number") {
  year = config.footer.copyright.yearUpdateStrategy;
} else {
  year = new Date().getFullYear();
}
---

<footer class="mt-auto w-full border-t border-white/10 bg-black/20 px-6 py-4 backdrop-blur-md">
  <div class="mx-auto flex w-full max-w-7xl items-center justify-between text-sm text-neutral-400">
    
    <div id="music-player-wrapper" transition:persist="music-player" class="relative">
      {/* Sửa viền hover sang Amber */}
      <button id="music-toggle" class="flex h-9 w-9 items-center justify-center rounded-md border border-white/20 transition-all hover:border-amber-500/50 hover:text-amber-500" title="Open Music Player">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"></path><circle cx="6" cy="18" r="3"></circle><circle cx="18" cy="16" r="3"></circle></svg>
      </button>

      <div id="music-panel" class="absolute bottom-14 left-0 w-[280px] bg-[#121212] border border-white/10 rounded-2xl p-4 shadow-2xl opacity-0 pointer-events-none translate-y-2 transition-all duration-300 z-50 flex flex-col gap-5">
        <div class="flex gap-3 items-center">
          <div class="w-12 h-12 bg-neutral-800 rounded-lg flex items-center justify-center text-white/40 font-bold">♫</div>
          <div class="flex flex-col overflow-hidden w-full">
            <span id="track-title" class="text-white font-bold text-sm truncate">Loading...</span>
            <span id="track-artist" class="text-neutral-400 text-xs truncate">Playlist</span>
          </div>
        </div>

        <div class="flex items-center justify-between text-neutral-400 px-1">
          <button id="btn-shuffle" class="hover:text-amber-500 transition-colors"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 3 21 3 21 8"></polyline><line x1="4" y1="20" x2="21" y2="3"></line><polyline points="21 16 21 21 16 21"></polyline><line x1="15" y1="15" x2="21" y2="21"></line><line x1="4" y1="4" x2="9" y2="9"></line></svg></button>
          <button id="btn-prev" class="hover:text-amber-500 transition-colors"><svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="19 20 9 12 19 4 19 20"></polygon><line x1="5" y1="19" x2="5" y2="5"></line></svg></button>
          {/* Nút Play màu Amber */}
          <button id="btn-play" class="w-11 h-11 bg-amber-500 text-black rounded-full flex items-center justify-center hover:scale-105 transition-transform shadow-[0_0_15px_rgba(245,158,11,0.4)]">
            <svg id="icon-play" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
            <svg id="icon-pause" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="hidden"><rect x="6" y="4" width="4" height="16"></rect><rect x="14" y="4" width="4" height="16"></rect></svg>
          </button>
          <button id="btn-next" class="hover:text-amber-500 transition-colors"><svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 4 15 12 5 20 5 4"></polygon><line x1="19" y1="5" x2="19" y2="19"></line></svg></button>
          <div class="w-[18px]"></div>
        </div>

        <div class="flex items-center gap-3 px-1">
          {/* Slider màu Amber */}
          <input type="range" id="volume-slider" min="0" max="1" step="0.01" value="0.3" class="w-full h-1 bg-neutral-700 rounded-lg appearance-none cursor-pointer accent-amber-500">
        </div>
      </div>
      <audio id="bg-audio" preload="metadata"></audio>
    </div>

    {/* Sửa tim tím sang tim cam, link sang màu amber */}
    <div class="hidden flex-1 text-center md:block">
      &copy; {year} | Made with <span class="text-amber-500">🧡</span> by <a href="/about" class="font-bold text-white hover:text-amber-500 transition-colors">{config.author.name}.</a>
    </div>

    <div class="flex items-center gap-5">
       <a href={config.author.links[0]?.to} target="_blank" class="hover:text-amber-500 transition-colors"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.2c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path></svg></a>
       
       {/* ĐÃ SỬA: Link về trang /contact thay vì mailto */}
       <a href="/contact" class="hover:text-amber-500 transition-colors">
         <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
       </a>

       <a href="/rss.xml" class="hover:text-amber-500 transition-colors"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"></path><path d="M4 4a16 16 0 0 1 16 16"></path><circle cx="5" cy="19" r="1"></circle></svg></a>
    </div>
  </div>
</footer>

<script>
  function initMusicPlayer() {
    const wrapper = document.getElementById('music-player-wrapper');
    if (!wrapper || wrapper.dataset.initialized === "true") return;
    wrapper.dataset.initialized = "true";

    const playlist = [
      { title: "The Wind Awakening", artist: "Chase9602", src: "/assets/music/chase9602-the-wind-awakening-memories-of-the-forest-468155.mp3" },
      { title: "Autumn Meditation", artist: "DamianSmith", src: "/assets/music/damiansmith-autumn-meditation-330279.mp3" },
      { title: "Days For You", artist: "Ryoish", src: "/assets/music/ryoish-days-for-you-336889.mp3" },
      { title: "Dignified", artist: "Ryoish", src: "/assets/music/ryoish-dignified-336885.mp3" },
      { title: "Five Days", artist: "Ryoish", src: "/assets/music/ryoish-five-days-336887.mp3" },
      { title: "Intimate", artist: "Ryoish", src: "/assets/music/ryoish-intimate-336890.mp3" },
      { title: "January", artist: "Ryoish", src: "/assets/music/ryoish-january-336894.mp3" },
      { title: "Peace", artist: "Ryoish", src: "/assets/music/ryoish-peace-336882.mp3" },
      { title: "The People's Land", artist: "Ryoish", src: "/assets/music/ryoish-the-peoplex27s-land-336886.mp3" },
      { title: "Thought", artist: "Ryoish", src: "/assets/music/ryoish-thought-336888.mp3" },
      { title: "Wednesday", artist: "Ryoish", src: "/assets/music/ryoish-wednesday-336893.mp3" },
      { title: "Path of the Wind Lofi", artist: "Sahtori", src: "/assets/music/sahtori-path-of-the-wind-lofi-223116.mp3" },
      { title: "Ghibli Style 1", artist: "Pixabay", src: "/assets/music/u_yl4sq8d6xg-ghibli-style-1-229069.mp3" },
      { title: "Ghibli Style 2", artist: "Pixabay", src: "/assets/music/u_yl4sq8d6xg-ghibli-style-2-229070.mp3" }
    ];

    let isShuffle = true;
    let currentIndex = 0;

    const audio = document.getElementById('bg-audio') as HTMLAudioElement;
    const btnToggle = document.getElementById('music-toggle');
    const panel = document.getElementById('music-panel');
    const btnPlay = document.getElementById('btn-play');
    const btnNext = document.getElementById('btn-next');
    const btnPrev = document.getElementById('btn-prev');
    const btnShuffle = document.getElementById('btn-shuffle');
    const volSlider = document.getElementById('volume-slider') as HTMLInputElement;
    const trackTitle = document.getElementById('track-title');
    const trackArtist = document.getElementById('track-artist');
    const iconPlay = document.getElementById('icon-play');
    const iconPause = document.getElementById('icon-pause');

    function loadTrack(index: number) {
      const track = playlist[index];
      if (trackTitle && trackArtist && audio) {
        trackTitle.textContent = track.title;
        trackArtist.textContent = track.artist;
        audio.src = track.src;
      }
    }

    function syncUI() {
      if (audio.paused) {
        iconPause?.classList.add('hidden');
        iconPlay?.classList.remove('hidden');
        {/* Đổi màu active sang Amber */}
        btnToggle?.classList.remove('border-amber-500', 'text-amber-500');
      } else {
        iconPlay?.classList.add('hidden');
        iconPause?.classList.remove('hidden');
        btnToggle?.classList.add('border-amber-500', 'text-amber-500');
      }
    }

    if (audio.src && audio.src.includes('.mp3')) {
      const currentSrc = audio.getAttribute('src') ?? "";
      currentIndex = playlist.findIndex(t => currentSrc.includes(t.src));
      if (currentIndex === -1) currentIndex = 0;
      if (trackTitle) trackTitle.textContent = playlist[currentIndex].title;
      if (trackArtist) trackArtist.textContent = playlist[currentIndex].artist;
      syncUI();
    } else {
      currentIndex = Math.floor(Math.random() * playlist.length);
      loadTrack(currentIndex);
      {/* Đổi màu shuffle mặc định sang Amber */}
      if (btnShuffle) btnShuffle.classList.add('text-amber-500');
    }

    btnToggle?.addEventListener('click', (e) => {
      e.stopPropagation();
      panel?.classList.toggle('opacity-0');
      panel?.classList.toggle('pointer-events-none');
      panel?.classList.toggle('translate-y-2');
    });

    btnPlay?.addEventListener('click', () => {
      if (audio.paused) audio.play(); else audio.pause();
      syncUI();
    });

    btnNext?.addEventListener('click', () => {
      currentIndex = isShuffle ? Math.floor(Math.random() * playlist.length) : (currentIndex + 1) % playlist.length;
      loadTrack(currentIndex);
      audio.play();
      syncUI();
    });

    btnPrev?.addEventListener('click', () => {
      currentIndex = (currentIndex - 1 + playlist.length) % playlist.length;
      loadTrack(currentIndex);
      audio.play();
      syncUI();
    });

    btnShuffle?.addEventListener('click', () => {
      isShuffle = !isShuffle;
      btnShuffle.classList.toggle('text-amber-500');
    });

    audio.addEventListener('ended', () => btnNext?.click());
    volSlider?.addEventListener('input', (e) => { audio.volume = parseFloat((e.target as HTMLInputElement).value); });
  }

  initMusicPlayer();
  document.addEventListener('astro:page-load', initMusicPlayer);
</script>