---
import { SITE_TITLE } from "../../consts.ts";
import config from "@shConfig";
import { Button } from "@ui/button.tsx";
import { Mail } from "lucide-react";
import { FAVICON_URL } from "../../consts.ts";
import { SearchDialog } from "../search/SearchDialog";

const links = config.navBar.links;
const { pathname } = Astro.url;

const checkActive = (href: string) => {
  if (href === '/' && pathname !== '/') return false;
  return pathname === href || pathname.startsWith(href);
};
---

<header class="fixed top-4.5 left-1/2 z-50 w-full max-w-[1278px] -translate-x-1/2 overflow-hidden rounded-2xl backdrop-blur-[6px]">
  <nav class="flex h-14 items-center justify-between rounded-2xl border border-white/10 bg-neutral-900/50 px-4 lg:px-2.5">
    <div class="flex items-center gap-2">
      <div class="h-9 w-9 overflow-hidden rounded-lg">
        <img src={FAVICON_URL} alt={SITE_TITLE} class="h-full w-full object-cover" />
      </div>
      <a class="hidden lg:block" href="/">
        <h1 class="font-funny text-2xl leading-none text-white capitalize">{SITE_TITLE}</h1>
      </a>
    </div>

    <div class="flex items-center gap-2 lg:gap-4">
      <div class="hidden items-center gap-1 pr-4 lg:flex">
        {links.map((link, index) => {
          const isActive = checkActive(link.href);
          return (
            <div class="flex items-center">
              <a 
                href={link.href} 
                class={`relative px-2 text-sm font-medium uppercase transition-all lg:px-4 ${isActive ? 'text-amber-500' : 'text-white hover:text-white/80'}`}
              >
                {link.title}
                {isActive && (
                  <span class="absolute -bottom-2 left-1/2 h-[2px] w-4 -translate-x-1/2 bg-amber-500 shadow-[0_0_10px_rgba(245,158,11,0.8)]" />
                )}
              </a>
              {index < links.length - 1 && <span class="text-sm text-neutral-400 select-none">/</span>}
            </div>
          )
        })}
      </div>

      <div class="flex items-center gap-1 lg:hidden">
        {links.map((link) => {
          const isActive = checkActive(link.href);
          return (
            <div class="flex items-center">
              <a 
                href={link.href} 
                class={`px-2 text-sm font-medium transition-all ${isActive ? 'text-amber-500 scale-110' : 'text-white hover:text-white/80'}`}
              >
                <link.icon size={16} />
              </a>
            </div>
          )
        })}
      </div>

      <div class="hidden items-center gap-2 md:flex">
        {/* ĐÃ SỬA TẠI ĐÂY: Trỏ về trang /contact thay vì mở mail client */}
        <a href="/contact">
          <Button client:load variant="ghost" size="icon" className="rounded-lg hover:bg-white/5">
            <Mail size={18} />
          </Button>
        </a>
        <SearchDialog client:load />
      </div>
    </div>
  </nav>
</header>