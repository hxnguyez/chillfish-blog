---
import { CardTitle } from "@ui/card";
import { ChevronDown } from "lucide-react";
import config from "@shConfig";
import I18nKey from "@i18n/i18nKey";
import i18n from "@i18n/translation";

interface Props {
  headings: Array<{
    depth: number;
    slug: string;
    text: string;
  }>;
}

const { headings } = Astro.props;

const cleanHeadingText = (text: string): string => {
  return text.replace("#", "").trim();
};

const minDepth = config.behavior.tableOfContents.minDepth || 2;
const maxDepth = config.behavior.tableOfContents.maxDepth || 4;

const tocTree = headings
  .filter(h => h.depth >= minDepth && (maxDepth === -1 || h.depth <= maxDepth))
  .reduce((acc, heading) => {
    const cleanText = cleanHeadingText(heading.text);
    if (heading.depth === minDepth) {
      acc.push({ ...heading, text: cleanText, children: [] });
    } else if (acc.length > 0) {
      acc[acc.length - 1].children.push({ ...heading, text: cleanText });
    }
    return acc;
  }, [] as Array<{ depth: number; slug: string; text: string; children: Array<{ depth: number; slug: string; text: string }> }>);
---

<div id="toc" class="mt-5 w-full border border-white/10 rounded-xl bg-neutral-900/40 backdrop-blur-md overflow-hidden shadow-2xl" data-pagefind-ignore>
  {tocTree.length > 0 && (
    <div class="flex flex-col max-h-[65vh]">
      <div class="border-b border-white/10 px-4 py-3 bg-white/5 flex items-center justify-between">
        <CardTitle className="text-white text-[11px] font-bold tracking-[0.2em] uppercase flex items-center gap-2">
          {/* Amber */}
          <span class="h-1.5 w-1.5 bg-amber-500 rounded-full shadow-[0_0_8px_#f59e0b] animate-pulse"></span>
          {i18n(I18nKey.post_toc_title)}
        </CardTitle>
        <span class="text-[10px] text-neutral-500 font-mono">[{headings.length}]</span>
      </div>
      
      <nav class="overflow-y-auto custom-scrollbar p-2" data-blog-toc-nav>
        <ol class="space-y-0.5" data-blog-toc>
          {tocTree.map((item, index) => (
            <li class="group/toc">
              <div class="flex items-center group">
                <a
                  href={`#${item.slug}`}
                  class={`toc-link toc-level-${item.depth} flex-1 truncate rounded-md px-3 py-1.5 text-[13px] text-neutral-400 transition-all hover:bg-white/5 hover:text-amber-500`}
                  data-heading-slug={item.slug}
                >
                  {item.text}
                </a>
                {item.children.length > 0 && (
                  <button 
                    class="toc-toggle p-1.5 text-neutral-600 hover:text-amber-500 transition-all"
                    data-toggle-target={`toc-children-${index}`}
                  >
                    <ChevronDown size={12} className="transition-transform duration-300" />
                  </button>
                )}
              </div>

              {item.children.length > 0 && (
                <ul
                  class="toc-children mt-0.5 mb-1 space-y-0.5 border-l border-white/10 ml-5 pl-2"
                  id={`toc-children-${index}`}
                >
                  {item.children.map((child) => (
                    <li>
                      <a
                        href={`#${child.slug}`}
                        class={`toc-link toc-level-${child.depth} block truncate rounded-md px-3 py-1 text-[11px] text-neutral-500 transition-all hover:text-amber-500 hover:bg-white/5`}
                        data-heading-slug={child.slug}
                      >
                        {child.text}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))}
        </ol>
      </nav>
    </div>
  )}
</div>

<style>
  .toc-link.active {
    color: #f59e0b !important;
    background: rgba(245, 158, 11, 0.08);
    font-weight: 600;
    padding-left: 1rem;
    border-left: 2px solid #f59e0b;
    border-radius: 0 4px 4px 0;
  }

  .custom-scrollbar::-webkit-scrollbar { width: 4px; }
  .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
  .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.05); border-radius: 10px; }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(245, 158, 11, 0.3); }

  .toc-children {
    transition: max-height 0.3s ease-out, opacity 0.2s ease;
  }
  .toc-children.hidden {
    display: none;
  }
</style>

<script is:inline>
  function initToC() {
    const headings = Array.from(document.querySelectorAll("article :is(h2,h3,h4,h5,h6)"));
    const tocLinks = document.querySelectorAll(".toc-link");
    const navContainer = document.querySelector("[data-blog-toc-nav]");
    
    if (!headings.length || !navContainer) return;

    headings.forEach(h => h.style.scrollMarginTop = "120px");

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          tocLinks.forEach(link => {
            if (link.getAttribute("data-heading-slug") === id) {
              link.classList.add("active");
              link.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            } else {
              link.classList.remove("active");
            }
          });
        }
      });
    }, { rootMargin: "-10% 0px -70% 0px", threshold: 0 });

    headings.forEach(h => observer.observe(h));

    // Fix click toggle
    document.querySelectorAll(".toc-toggle").forEach(btn => {
      btn.onclick = (e) => {
        e.preventDefault();
        const target = document.getElementById(btn.dataset.toggleTarget);
        if (target) {
          target.classList.toggle("hidden");
          btn.querySelector('svg').style.transform = target.classList.contains("hidden") ? "rotate(-90deg)" : "rotate(0deg)";
        }
      };
    });
  }

  document.addEventListener('astro:page-load', initToC);
  initToC();
</script>