---
import { Hash } from "lucide-react";
import { Badge } from "@ui/badge";
import { slugTag } from "@lib/tag";

const { tags, collection = "blog" } = Astro.props;
---

{
  tags && tags.length > 0 ? (
    <div class="tags-list flex items-center gap-2">
      {tags.map((tag: string) => (
        <a href={`/tags/${slugTag(tag)}`} class="tag-link">
          <Badge variant="secondary" className="px-2 text-sm" client:only>
            <Hash size={14} />
            {tag}
          </Badge>
        </a>
      ))}
    </div>
  ) : null
}
